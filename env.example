# =============================================================================
# CryoFlix — Template de Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores:
#   copy env.example .env       (Windows CMD)
#   cp env.example .env         (Linux/Mac/PowerShell)
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=cryoflix
POSTGRES_PASSWORD=cryoflix123
POSTGRES_DB=cryoflix

# ─── JWT ─────────────────────────────────────────────────────────────────────
# IMPORTANTE: troque esses valores em producao (minimo 32 caracteres)
JWT_SECRET=change-this-jwt-secret-min-32-chars-in-production
REFRESH_SECRET=change-this-refresh-secret-min-32-chars-in-production

# ─── TMDb API ────────────────────────────────────────────────────────────────
# Obtenha sua chave em: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Redis ───────────────────────────────────────────────────────────────────
# Deixe em branco para rodar sem senha (rede interna Docker)
REDIS_PASSWORD=

# ─── SMTP / E-mail (opcional) ────────────────────────────────────────────────
# Se deixar em branco, links de verificacao aparecem apenas no console do backend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── URLs da aplicacao (usadas nos links de e-mail) ───────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://backend:4000

# ─── Credenciais do Admin (seed inicial) ─────────────────────────────────────
ADMIN_EMAIL=admin@cryoflix.io
ADMIN_PASSWORD=Admin@CryoFlix2024!

# ─── OpenSubtitles (opcional) ────────────────────────────────────────────────
OPENSUBTITLES_API_KEY=
