PORT=4000
NODE_ENV=development
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
REFRESH_SECRET=change-me-refresh
REFRESH_EXPIRES_IN=7d
CDN_BASE_URL=https://cdn.fflix.local
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
SUPEREMBED_BASE_URL=https://multiembed.mov
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=fflix-demo
OPENSUBTITLES_USER_AGENT=FFlix/1.0
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_URL=redis://localhost:6379

# Banco de dados (opcional — sem DATABASE_URL o backend usa persistência em memória)
DATABASE_URL=postgresql://user:password@localhost:5432/cryoflix_db

# Admin (seed Prisma)
ADMIN_EMAIL=admin@cryoflix.io
ADMIN_PASSWORD=Admin@CryoFlix2024!

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# URLs para links de e-mail
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
API_URL=http://localhost:4000
